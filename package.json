{
  "name": "weeklog",
  "version": "1.3.6",
  "description": "WeekLog — 本地 Git 周报/日报生成桌面客户端（commit + 笔记双信息源，AI 融合总结，支持 OpenAI Responses / Anthropic Messages）",
  "main": "src/main/index.js",
  "license": "MIT",
  "scripts": {
    "start": "npm run build:renderer && node scripts/run-electron.js .",
    "dev:renderer": "vite",
    "dev": "npm run build:renderer && cross-env WEEKLOG_DEV=1 node scripts/run-electron.js .",
    "build:renderer": "vite build",
    "typecheck": "tsc --noEmit",
    "dist:win": "npm run build:renderer && electron-builder --win --x64 --publish never",
    "dist:mac": "npm run build:renderer && electron-builder --mac --arm64 --publish never",
    "dist": "npm run build:renderer && electron-builder --win --x64 --mac --arm64 --publish never"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "cross-env": "^7.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.16"
  },
  "build": {
    "appId": "com.weeklog.desktop",
    "productName": "WeekLog",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "build/icon.png",
      "src/**/*",
      "!src/renderer/src/**",
      "!src/renderer/public/**",
      "!src/renderer/index.html",
      "!src/renderer/quicknote.html",
      "!src/renderer/vite.config.*"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "include": "build/installer.nsh"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "kiritoko1029",
        "repo": "ai-week-log"
      }
    ]
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-radio-group": "^1.4.0",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-toggle-group": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "packageManager": "pnpm@11.6.0"
}
