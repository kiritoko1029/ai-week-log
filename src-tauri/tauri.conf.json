{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WeekLog",
  "version": "1.3.8",
  "identifier": "com.weeklog.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev:renderer:tauri",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "pnpm build:renderer:tauri",
    "frontendDist": "../src/renderer/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "WeekLog — Git 周报/日报生成工具",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "url": "index.html",
        "visible": true
      },
      {
        "label": "quicknote",
        "title": "快速记笔记",
        "url": "quicknote.html",
        "width": 480,
        "height": 360,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../build/icon.ico",
      "../build/icon.png"
    ],
    "resources": [],
    "externalBin": []
  }
}
